{
	"compilerOptions": {
		"target": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"erasableSyntaxOnly": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
